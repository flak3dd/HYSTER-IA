# --- PostgreSQL / Prisma ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hysteria2?schema=public

# --- Supabase (optional — for Realtime node updates on dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Hysteria 2 Traffic Stats API ---
HYSTERIA_TRAFFIC_API_BASE_URL=http://127.0.0.1:25000
HYSTERIA_TRAFFIC_API_SECRET=

# --- Hysteria egress (for agent outbound HTTP) ---
HYSTERIA_EGRESS_PROXY_URL=socks5://127.0.0.1:1080

# --- LLM provider ---
# When OPENROUTER_API_KEY is set, routing tries OpenRouter first, then Anthropic/OpenAI/Google/Azure/legacy Grok fallbacks based on configured keys.
# Without OpenRouter, typical order follows configured keys plus Grok as terminal fallback — see lib/ai/openrouter/stack.ts (PROVIDER_FALLBACK_SEQUENCE).

# Option 1 (recommended): xAI Grok (default — used for ShadowGrok and all chat)
XAI_API_KEY=your-xai-grok-api-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3

# Option 2: Azure OpenAI
# Create a deployment in https://ai.azure.com/ then fill in:
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o            # deployment name (not model name)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Foundry project endpoint (for future Foundry SDK features)
AZURE_AI_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/YOUR-PROJECT

# Option 3: OpenRouter (when OPENROUTER_API_KEY is set, routing tries OpenRouter first)
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_APP_TITLE=Hysteria2 Panel
# OPENROUTER_MODEL_CHAT_DEFAULT=
# Reasoning / structured-JSON model used by lib/ai/reasoning-orchestrator (generateObject)
# Pick a model with first-class json_schema strict support — see
# https://openrouter.ai/models?supported_parameters=structured_outputs
# OPENROUTER_MODEL_REASONING_JSON=anthropic/claude-sonnet-4.5
# OPENROUTER_MODEL_CHEAP=

# Option 4: Legacy / custom OpenAI-compatible endpoint
# LLM_PROVIDER_BASE_URL=https://api.x.ai/v1
# LLM_PROVIDER_API_KEY=your-api-key
# LLM_MODEL=grok-3

# --- ShadowGrok (xAI Grok) Configuration ---
# Enable ShadowGrok autonomous C2 operations
SHADOWGROK_ENABLED=false

# xAI Grok API Configuration (shared with primary LLM provider above)
XAI_API_KEY=your-xai-grok-api-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3

# ShadowGrok Safety Settings
SHADOWGROK_REQUIRE_APPROVAL=true
SHADOWGROK_MAX_TOOL_ROUNDS=15
SHADOWGROK_MAX_CONCURRENT_TOOLS=5
SHADOWGROK_EXECUTION_TIMEOUT_MS=300000

# ShadowGrok Risk Assessment
SHADOWGROK_RISK_THRESHOLD=70
SHADOWGROK_AUTO_APPROVE_LOW_RISK=true

# ShadowGrok Enhanced Tool Calling Configuration
SHADOWGROK_ENABLE_PARALLEL_EXECUTION=true
SHADOWGROK_PARALLEL_BATCH_SIZE=3
SHADOWGROK_AUTO_APPROVE_THRESHOLD=30
SHADOWGROK_TOOL_CALLING_AGGRESSIVENESS=balanced  # conservative | balanced | aggressive
SHADOWGROK_ENABLE_STREAMING_BY_DEFAULT=true

# --- Redis (optional - for rate limiting and caching) ---
REDIS_URL=redis://localhost:6379

# --- OSINT & Threat Intelligence API Keys ---
# VirusTotal API v3
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# AlienVault OTX API
ALIENVAULT_OTX_KEY=your-alienvault-otx-api-key

# Abuse.ch feeds (no API key required, but you can add for future use)
# ABUSECH_API_KEY= (currently not required)

# Additional OSINT APIs (optional)
# Hunter.io for email harvesting
HUNTER_API_KEY=your-hunter-io-api-key

# Shodan API for network mapping
SHODAN_API_KEY=your-shodan-api-key

# Censys API for network mapping
CENSYS_API_ID=your-censys-api-id
CENSYS_API_SECRET=your-censys-api-secret

# --- Admin Setup ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- AI & Autonomous Systems ---
# Enable/disable individual AI systems
ENABLE_AI_SCHEDULING=true
ENABLE_AI_OPTIMIZATION=true
ENABLE_AI_PREDICTIVE_CACHE=true
ENABLE_AI_THREAT_CORRELATION=true
ENABLE_AI_ANOMALY_DETECTION=true

# Auto-initialize AI systems on startup
AUTO_INIT_AI=true

# AI optimization interval (milliseconds)
AI_OPTIMIZATION_INTERVAL=300000