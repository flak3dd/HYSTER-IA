# --- PostgreSQL / Prisma ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hysteria2?schema=public

# --- Supabase (for Realtime subscriptions) ---
# Option A: Supabase Cloud (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Option B: Self-hosted Supabase (see docker-compose.supabase.yml)
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# --- Hysteria 2 Traffic Stats API ---
# See https://v2.hysteria.network/docs/advanced/Traffic-Stats-API/
HYSTERIA_TRAFFIC_API_BASE_URL=http://127.0.0.1:25000
HYSTERIA_TRAFFIC_API_SECRET=

# --- Hysteria egress proxy (used by agents) ---
# socks5://host:port or http://host:port of a running Hysteria 2 client
HYSTERIA_EGRESS_PROXY_URL=socks5://127.0.0.1:1080

# --- LLM provider (any OpenAI-compatible API) ---
# Blackbox AI:
LLM_PROVIDER_BASE_URL=https://api.blackbox.ai/api/chat
# LLM_PROVIDER_API_KEY=
LLM_MODEL=blackboxai/openai/gpt-4o

# OpenAI (alternative):
# LLM_PROVIDER_BASE_URL=https://api.openai.com/v1/chat/completions
# LLM_PROVIDER_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# --- VPS Provider API Keys (for automated node deployment) ---
# Set one or more to enable one-click deployment on /admin/nodes.
# Hetzner Cloud: https://console.hetzner.cloud/ -> API tokens
HETZNER_API_KEY=
# DigitalOcean: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_API_KEY=
# Vultr: https://my.vultr.com/settings/#settingsapi
VULTR_API_KEY=
# AWS Lightsail: IAM user with lightsail:* permissions
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- Optional: hysteria binary management ---
# Only set if you want the panel to manage the hysteria process lifecycle.
# Strongly recommended to run hysteria via systemd in production instead.
HYSTERIA_BINARY_PATH=
HYSTERIA_CONFIG_PATH=
HYSTERIA_DATA_DIR=
